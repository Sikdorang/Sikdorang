{
    "swagger": "2.0",
    "info": {
        "description": "API 문서",
        "title": "My API",
        "contact": {},
        "version": "1.0"
    },
    "host": "Localhost:4000",
    "basePath": "/api",
    "paths": {
        "/auth/login": {
            "post": {
                "description": "아이디와 비밀번호로 로그인하여 Access/Refresh Token 발급",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "로그인",
                "parameters": [
                    {
                        "description": "로그인 요청",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.LoginRequestDTO"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.LoginResponseDTO"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "description": "Refresh Token을 무효화하고 쿠키에서 제거합니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "로그아웃",
                "responses": {
                    "200": {
                        "description": "로그아웃 성공",
                        "schema": {
                            "$ref": "#/definitions/dto.LogoutResponseDTO"
                        }
                    },
                    "500": {
                        "description": "서버 에러",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/refresh": {
            "post": {
                "description": "Refresh Token을 사용하여 새로운 Access Token을 발급합니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Access Token 갱신",
                "responses": {
                    "200": {
                        "description": "accessToken 응답",
                        "schema": {
                            "$ref": "#/definitions/dto.RefreshTokenResponseDTO"
                        }
                    },
                    "401": {
                        "description": "Refresh Token 누락 또는 유효하지 않음",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/categories": {
            "get": {
                "description": "storeID에 해당하는 카테고리 이름 목록을 조회합니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "category"
                ],
                "summary": "카테고리 목록 조회",
                "responses": {
                    "200": {
                        "description": "카테고리 이름 배열",
                        "schema": {
                            "$ref": "#/definitions/dto.GetCategoryResponseDTO"
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "조회 실패",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "storeID에 해당하는 카테고리를 추가합니다.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "category"
                ],
                "summary": "카테고리 생성",
                "parameters": [
                    {
                        "description": "카테고리 요청 데이터",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.CreateCategoryRequestDTO"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "생성된 카테고리 응답",
                        "schema": {
                            "$ref": "#/definitions/dto.CreateCategoryResponseDTO"
                        }
                    },
                    "400": {
                        "description": "잘못된 요청",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "인증 실패",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "서버 에러",
                        "schema": {
                            "$ref": "#/definitions/dto.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.CreateCategoryRequestDTO": {
            "type": "object",
            "required": [
                "category"
            ],
            "properties": {
                "category": {
                    "type": "string",
                    "example": "증류주"
                }
            }
        },
        "dto.CreateCategoryResponseDTO": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string",
                    "example": "음료"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "storeId": {
                    "type": "integer",
                    "example": 2
                }
            }
        },
        "dto.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "unauthorized"
                }
            }
        },
        "dto.GetCategoryResponseDTO": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "[\"음료\"",
                        " \"디저트\"]"
                    ]
                }
            }
        },
        "dto.LoginRequestDTO": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string",
                    "example": "1234"
                },
                "userId": {
                    "type": "string",
                    "example": "admin123"
                }
            }
        },
        "dto.LoginResponseDTO": {
            "type": "object",
            "properties": {
                "accessToken": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR..."
                }
            }
        },
        "dto.LogoutResponseDTO": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "logout success"
                }
            }
        },
        "dto.RefreshTokenResponseDTO": {
            "type": "object",
            "properties": {
                "accessToken": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                }
            }
        }
    }
}